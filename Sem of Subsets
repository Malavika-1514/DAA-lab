#include <iostream>
using namespace std;

int w[20], x[20];
int n, target;

void sumOfSubsets(int s, int k, int r)
{
    x[k] = 1;

    if (s + w[k] == target)
    {
        cout << "Subset: ";
        for (int i = 0; i <= k; i++)
        {
            if (x[i] == 1)
                cout << w[i] << " ";
        }
        cout << endl;
    }
    else if (s + w[k] + w[k + 1] <= target)
    {
        sumOfSubsets(s + w[k], k + 1, r - w[k]);
    }

    if ((s + r - w[k] >= target) && (s + w[k + 1] <= target))
    {
        x[k] = 0;
        sumOfSubsets(s, k + 1, r - w[k]);
    }
}

int main()
{
    int sum = 0;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements in increasing order:\n";
    for (int i = 0; i < n; i++)
    {
        cin >> w[i];
        sum += w[i];
    }

    cout << "Enter target sum: ";
    cin >> target;

    sumOfSubsets(0, 0, sum);

    return 0;
}
